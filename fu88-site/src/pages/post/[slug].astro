---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, SITE } from '../../consts';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter((p) => !p.data.draft);
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const d = post.data;
const url = new URL(`/post/${post.slug}/`, SITE.url).href;
const img = d.cover ? new URL(d.cover, SITE.url).href : undefined;
const catName = CATEGORIES[d.category];
const fmt = (x) => x.toISOString().slice(0, 10);

// === 自動封面圖（無 cover 時 build 生成的品牌 SVG 主圖）===
const FF = '"PingFang TC","Microsoft JhengHei","Noto Sans TC",system-ui,sans-serif';
const host = new URL(SITE.url).host;
const ACCENT = {
  'platform-guide': '#c1954e',
  'register-account': '#6fa8c9',
  'app-mobile': '#7cb890',
  'promotions': '#d98a5a',
  'deposit-withdraw': '#b98fd0',
  'game-guide': '#d06b74',
  'security': '#5fb0a8',
  'customer-service': '#cbb26a',
};
const accent = ACCENT[d.category] ?? '#c1954e';
const titleLines = (() => {
  const per = 13, maxLines = 3;
  const chars = [...d.title];
  const lines = [];
  for (let i = 0; i < chars.length; i += per) lines.push(chars.slice(i, i + per).join(''));
  if (lines.length > maxLines) {
    const kept = lines.slice(0, maxLines);
    kept[maxLines - 1] = [...kept[maxLines - 1]].slice(0, per - 1).join('') + '…';
    return kept;
  }
  return lines;
})();
const titleFont = titleLines.length >= 3 ? 58 : 72;
const titleY = ({ 1: [286], 2: [246, 324], 3: [206, 280, 354] })[titleLines.length] || [206, 280, 354];

// 結構化資料（BlogPosting + 麵包屑 +（若有）FAQ）
const graph = [
  {
    '@type': 'BlogPosting',
    headline: d.title,
    description: d.description,
    datePublished: d.pubDate.toISOString(),
    dateModified: (d.updatedDate ?? d.pubDate).toISOString(),
    author: { '@type': 'Organization', name: d.author },
    publisher: { '@type': 'Organization', name: SITE.name },
    mainEntityOfPage: url,
    ...(img ? { image: img } : {}),
    keywords: d.tags.join(', '),
    articleSection: catName,
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: '首頁', item: SITE.url + '/' },
      { '@type': 'ListItem', position: 2, name: '部落格', item: SITE.url + '/blog/' },
      { '@type': 'ListItem', position: 3, name: catName, item: `${SITE.url}/blog/categories/${d.category}/` },
      { '@type': 'ListItem', position: 4, name: d.title, item: url },
    ],
  },
];
if (d.faq.length) {
  graph.push({
    '@type': 'FAQPage',
    mainEntity: d.faq.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  });
}
const jsonLd = { '@context': 'https://schema.org', '@graph': graph };
---
<Base title={d.title} description={d.description} image={d.cover} type="article" jsonLd={jsonLd}>
  <article class="article">
    <div class="wrap-narrow" style="padding:34px 24px 10px">
      <nav class="breadcrumb" aria-label="麵包屑">
        <a href="/">首頁</a> › <a href="/blog/">部落格</a> ›
        <a href={`/blog/categories/${d.category}/`}>{catName}</a> › <span>{d.title}</span>
      </nav>
      <span class="chip">{catName}</span>
      <h1 style="font-size:34px; font-weight:900; line-height:1.4; margin:14px 0 10px; letter-spacing:.5px">{d.title}</h1>
      <div class="post-meta" style="margin-bottom:6px">
        <time datetime={d.pubDate.toISOString()}>{fmt(d.pubDate)}</time>
        <span>· {d.author}</span>
      </div>
    </div>

    {d.cover ? (
      <div class="wrap-narrow" style="padding:0 24px">
        <img src={d.cover} alt={d.coverAlt ?? d.title} width="1920" height="700"
          style="width:100%; border-radius:16px; box-shadow:0 12px 32px rgba(150,110,50,.18)" />
      </div>
    ) : (
      <div class="wrap-narrow" style="padding:0 24px">
        <svg viewBox="0 0 1200 480" role="img" aria-label={d.coverAlt ?? d.title}
          style="width:100%; height:auto; display:block; border-radius:16px; box-shadow:0 12px 32px rgba(150,110,50,.18)">
          <defs>
            <linearGradient id="fu88bg" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0" stop-color="#2b2013" />
              <stop offset="1" stop-color="#4c3a22" />
            </linearGradient>
            <radialGradient id="fu88glow" cx="0.82" cy="0.18" r="0.9">
              <stop offset="0" stop-color={accent} stop-opacity="0.55" />
              <stop offset="0.5" stop-color={accent} stop-opacity="0.12" />
              <stop offset="1" stop-color={accent} stop-opacity="0" />
            </radialGradient>
            <pattern id="fu88dots" width="26" height="26" patternUnits="userSpaceOnUse">
              <circle cx="2" cy="2" r="1.4" fill="#ffffff" opacity="0.05" />
            </pattern>
          </defs>
          <rect width="1200" height="480" fill="url(#fu88bg)" />
          <rect width="1200" height="480" fill="url(#fu88dots)" />
          <rect width="1200" height="480" fill="url(#fu88glow)" />
          <rect x="0" y="0" width="1200" height="6" fill={accent} />
          <rect x="90" y="70" width="10" height="46" rx="3" fill={accent} />
          <text x="118" y="103" font-size="30" font-weight="700" fill="#efe3cb" style={`font-family:${FF}; letter-spacing:2px`}>{catName}</text>
          {titleLines.map((ln, i) => (
            <text x="90" y={titleY[i]} font-size={titleFont} font-weight="900" fill="#f8efd9" style={`font-family:${FF}; letter-spacing:1px`}>{ln}</text>
          ))}
          <text x="90" y="438" font-size="36" font-weight="900" fill="#e6cd97" style={`font-family:${FF}; letter-spacing:1px`}>{SITE.brand}<tspan font-size="24" fill="#cdb383" dx="8">娛樂城</tspan></text>
          <text x="1110" y="438" text-anchor="end" font-size="22" fill="#b49a68" style={`font-family:${FF}`}>{host}</text>
        </svg>
      </div>
    )}

    {d.steps.length > 0 && (
      <div class="wrap-narrow" style="padding:24px 24px 4px">
        <h2 style="font-size:26px; font-weight:900; margin:6px 0 18px; padding-left:14px; border-left:5px solid var(--gold)">操作步驟</h2>
        <ol style="list-style:none; margin:0; padding:0">
          {d.steps.map((s, i) => (
            <li style="display:flex; gap:16px; align-items:stretch">
              <div style="flex:none; display:flex; flex-direction:column; align-items:center">
                <div style="width:42px; height:42px; border-radius:50%; background:linear-gradient(135deg,#e6cd97,#c1954e); color:#3a2b12; font-weight:900; font-size:19px; display:flex; align-items:center; justify-content:center; box-shadow:0 3px 10px rgba(180,140,70,.35)">{i + 1}</div>
                {i < d.steps.length - 1 && <div style="width:2px; flex:1; min-height:16px; margin:6px 0; background:linear-gradient(#dbb37e,rgba(219,179,126,.25))"></div>}
              </div>
              <div style="flex:1; padding:6px 0 22px">
                <div style="font-weight:800; font-size:18px; color:#3a3020; line-height:1.5">{s.t}</div>
                {s.d && <div style="margin-top:5px; color:#5a5140; font-size:15.5px; line-height:1.75">{s.d}</div>}
              </div>
            </li>
          ))}
        </ol>
        <a href={`/steps/${post.slug}.svg`} target="_blank" rel="noopener"
          style="display:inline-flex; align-items:center; gap:6px; margin-top:2px; font-size:14px; font-weight:700; color:var(--gold-deep)">下載可分享步驟圖 ›</a>
      </div>
    )}

    <div class="wrap-narrow prose" style="padding:26px 24px 8px">
      <Content />
    </div>

    {d.faq.length > 0 && (
      <div class="wrap-narrow" style="padding:18px 24px 8px">
        <h2 style="font-size:26px; font-weight:900; margin:22px 0 14px; padding-left:14px; border-left:5px solid var(--gold)">常見問題 FAQ</h2>
        {d.faq.map((f) => (
          <details class="faq-item">
            <summary>{f.q}</summary>
            <div class="a">{f.a}</div>
          </details>
        ))}
      </div>
    )}

    {d.tags.length > 0 && (
      <div class="wrap-narrow" style="padding:14px 24px 8px; display:flex; flex-wrap:wrap; gap:8px">
        {d.tags.map((t) => <span class="pill" style="cursor:default">#{t}</span>)}
      </div>
    )}

    <section id="cta" style="position:relative; overflow:hidden; background:linear-gradient(135deg,#c94b57,#8f1f2c); margin-top:40px">
      <div style="position:absolute; inset:0; background-image:radial-gradient(rgba(255,255,255,.16) 1px,transparent 1px); background-size:22px 22px; opacity:.6"></div>
      <div style="position:relative; max-width:820px; margin:0 auto; padding:52px 32px; text-align:center; color:#fff">
        <h2 style="font-size:30px; font-weight:900; margin:0 0 12px; color:#fff">新會員註冊即送 288 體驗金</h2>
        <p style="font-size:16px; margin:0 auto 26px; max-width:460px; color:rgba(255,255,255,.92)">看完攻略，直接開始你的第一場遊戲。</p>
        <a href="/" class="cta-btn">回首頁免費註冊 ›</a>
      </div>
    </section>
  </article>
</Base>
